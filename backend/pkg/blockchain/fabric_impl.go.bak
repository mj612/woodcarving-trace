package blockchain

import (
	"encoding/json"
	"fmt"
	"log"
	localconfig "woodcarving-backend/config"

	"github.com/hyperledger/fabric-sdk-go/pkg/core/config"
	"github.com/hyperledger/fabric-sdk-go/pkg/gateway"
)

var contract *gateway.Contract

// InitFabric 初始化Fabric连接
func InitFabric() error {
	cfg := localconfig.GlobalConfig.Fabric

	wallet, err := gateway.NewFileSystemWallet("wallet")
	if err != nil {
		return fmt.Errorf("创建钱包失败: %v", err)
	}

	if !wallet.Exists(cfg.UserName) {
		return fmt.Errorf("用户身份不存在")
	}

	gw, err := gateway.Connect(
		gateway.WithConfig(config.FromFile(cfg.ConfigPath)),
		gateway.WithIdentity(wallet, cfg.UserName),
	)
	if err != nil {
		return fmt.Errorf("连接网关失败: %v", err)
	}

	network, err := gw.GetNetwork(cfg.ChannelName)
	if err != nil {
		return fmt.Errorf("获取网络失败: %v", err)
	}

	contract = network.GetContract(cfg.ChaincodeName)

	log.Println("Fabric SDK初始化成功")
	return nil
}

// FabricCreateRawMaterial 创建原料（Fabric版本）
func FabricCreateRawMaterial(materialID, woodType, origin, harvestCert, supplierID, supplierName string,
	quantity float64, quality, certHash string) (string, error) {

	result, err := contract.SubmitTransaction("CreateRawMaterial",
		materialID, woodType, origin, harvestCert, supplierID, supplierName,
		fmt.Sprintf("%.2f", quantity), quality, certHash)

	if err != nil {
		return "", fmt.Errorf("创建原料失败: %v", err)
	}

	return string(result), nil
}

// CreateProduct 创建产品
func CreateProduct(productID, productName, materialID, artisanID, artisanName, dimensions string,
	weight float64, craftDesc, designHash, imageHash string, carveTime int) (string, error) {

	result, err := contract.SubmitTransaction("CreateProduct",
		productID, productName, materialID, artisanID, artisanName, dimensions,
		fmt.Sprintf("%.2f", weight), craftDesc, designHash, imageHash, fmt.Sprintf("%d", carveTime))

	if err != nil {
		return "", fmt.Errorf("创建产品失败: %v", err)
	}

	return string(result), nil
}

