// GetMaterialByID 查询原料
func GetMaterialByID(materialID string) (map[string]interface{}, error) {
	result, err := contract.EvaluateTransaction("GetMaterialByID", materialID)
	if err != nil {
		return nil, fmt.Errorf("查询原料失败: %v", err)
	}

	var material map[string]interface{}
	err = json.Unmarshal(result, &material)
	if err != nil {
		return nil, err
	}

	return material, nil
}

