{"ast":null,"code":"import { getProductList } from '@/api';\nexport default {\n  name: 'ProductList',\n  data() {\n    return {\n      products: [],\n      loading: false\n    };\n  },\n  mounted() {\n    this.loadProducts();\n  },\n  methods: {\n    async loadProducts() {\n      this.loading = true;\n      try {\n        const res = await getProductList();\n        // 修复：API返回的是 { list: [], total: 0 } 格式\n        const list = res.data && res.data.list ? res.data.list : [];\n        // 从链上数据中提取字段到顶层\n        this.products = list.map(item => {\n          const chainData = item.chainData || {};\n          return {\n            ...item,\n            productId: item.productId || chainData.productId,\n            productName: chainData.productName || '',\n            dimensions: chainData.dimensions || '',\n            weight: chainData.weight || 0,\n            status: chainData.status || 'unknown'\n          };\n        });\n      } catch (error) {\n        console.error('加载产品列表失败:', error);\n        this.$message.error('加载产品列表失败');\n        this.products = [];\n      } finally {\n        this.loading = false;\n      }\n    },\n    getStatusType(status) {\n      const map = {\n        'produced': 'success',\n        'in_storage': 'warning',\n        'sold': 'info'\n      };\n      return map[status] || 'info';\n    },\n    getStatusText(status) {\n      const map = {\n        'produced': '制作完成',\n        'in_storage': '库存中',\n        'sold': '已售出'\n      };\n      return map[status] || status;\n    },\n    viewDetail(row) {\n      this.$router.push(`/dashboard/products/${row.productId}`);\n    },\n    transfer(row) {\n      console.log('转移产品:', row);\n    }\n  }\n};","map":{"version":3,"names":["getProductList","name","data","products","loading","mounted","loadProducts","methods","res","list","map","item","chainData","productId","productName","dimensions","weight","status","error","console","$message","getStatusType","getStatusText","viewDetail","row","$router","push","transfer","log"],"sources":["src/views/product/List.vue"],"sourcesContent":["<template>\n  <div class=\"product-list\">\n    <div class=\"page-container\">\n      <div class=\"action-bar\">\n        <h2>产品列表</h2>\n        <el-button type=\"primary\" @click=\"$router.push('/dashboard/products/create')\">\n          创建产品\n        </el-button>\n      </div>\n      \n      <div class=\"card\">\n        <el-table :data=\"products\" style=\"width: 100%\" v-loading=\"loading\">\n          <el-table-column prop=\"productId\" label=\"产品ID\" width=\"150\"></el-table-column>\n          <el-table-column prop=\"productName\" label=\"产品名称\" width=\"180\"></el-table-column>\n          <el-table-column prop=\"dimensions\" label=\"尺寸\" width=\"120\"></el-table-column>\n          <el-table-column prop=\"weight\" label=\"重量(kg)\" width=\"100\"></el-table-column>\n          <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n            <template slot-scope=\"scope\">\n              <el-tag :type=\"getStatusType(scope.row.status)\">\n                {{ getStatusText(scope.row.status) }}\n              </el-tag>\n            </template>\n          </el-table-column>\n          <el-table-column prop=\"createdAt\" label=\"创建时间\" width=\"180\"></el-table-column>\n          <el-table-column label=\"操作\" width=\"150\">\n            <template slot-scope=\"scope\">\n              <el-button size=\"mini\" @click=\"viewDetail(scope.row)\">查看</el-button>\n              <el-button size=\"mini\" type=\"primary\" @click=\"transfer(scope.row)\" \n                         v-if=\"scope.row.status === 'produced'\">转移</el-button>\n            </template>\n          </el-table-column>\n        </el-table>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { getProductList } from '@/api'\n\nexport default {\n  name: 'ProductList',\n  data() {\n    return {\n      products: [],\n      loading: false\n    }\n  },\n  \n  mounted() {\n    this.loadProducts()\n  },\n  methods: {\n    async loadProducts() {\n      this.loading = true\n      try {\n        const res = await getProductList()\n        // 修复：API返回的是 { list: [], total: 0 } 格式\n        const list = (res.data && res.data.list) ? res.data.list : []\n        // 从链上数据中提取字段到顶层\n        this.products = list.map(item => {\n          const chainData = item.chainData || {}\n          return {\n            ...item,\n            productId: item.productId || chainData.productId,\n            productName: chainData.productName || '',\n            dimensions: chainData.dimensions || '',\n            weight: chainData.weight || 0,\n            status: chainData.status || 'unknown'\n          }\n        })\n      } catch (error) {\n        console.error('加载产品列表失败:', error)\n        this.$message.error('加载产品列表失败')\n        this.products = []\n      } finally {\n        this.loading = false\n      }\n    },\n    \n    getStatusType(status) {\n      const map = {\n        'produced': 'success',\n        'in_storage': 'warning',\n        'sold': 'info'\n      }\n      return map[status] || 'info'\n    },\n    \n    getStatusText(status) {\n      const map = {\n        'produced': '制作完成',\n        'in_storage': '库存中',\n        'sold': '已售出'\n      }\n      return map[status] || status\n    },\n    \n    viewDetail(row) {\n      this.$router.push(`/dashboard/products/${row.productId}`)\n    },\n    \n    transfer(row) {\n      console.log('转移产品:', row)\n    }\n  }\n}\n</script>"],"mappings":"AAsCA,SAAAA,cAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,OAAA;IACA;EACA;EAEAC,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACA,MAAAD,aAAA;MACA,KAAAF,OAAA;MACA;QACA,MAAAI,GAAA,SAAAR,cAAA;QACA;QACA,MAAAS,IAAA,GAAAD,GAAA,CAAAN,IAAA,IAAAM,GAAA,CAAAN,IAAA,CAAAO,IAAA,GAAAD,GAAA,CAAAN,IAAA,CAAAO,IAAA;QACA;QACA,KAAAN,QAAA,GAAAM,IAAA,CAAAC,GAAA,CAAAC,IAAA;UACA,MAAAC,SAAA,GAAAD,IAAA,CAAAC,SAAA;UACA;YACA,GAAAD,IAAA;YACAE,SAAA,EAAAF,IAAA,CAAAE,SAAA,IAAAD,SAAA,CAAAC,SAAA;YACAC,WAAA,EAAAF,SAAA,CAAAE,WAAA;YACAC,UAAA,EAAAH,SAAA,CAAAG,UAAA;YACAC,MAAA,EAAAJ,SAAA,CAAAI,MAAA;YACAC,MAAA,EAAAL,SAAA,CAAAK,MAAA;UACA;QACA;MACA,SAAAC,KAAA;QACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA,KAAAE,QAAA,CAAAF,KAAA;QACA,KAAAf,QAAA;MACA;QACA,KAAAC,OAAA;MACA;IACA;IAEAiB,cAAAJ,MAAA;MACA,MAAAP,GAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAO,MAAA;IACA;IAEAK,cAAAL,MAAA;MACA,MAAAP,GAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAO,MAAA,KAAAA,MAAA;IACA;IAEAM,WAAAC,GAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,wBAAAF,GAAA,CAAAX,SAAA;IACA;IAEAc,SAAAH,GAAA;MACAL,OAAA,CAAAS,GAAA,UAAAJ,GAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}