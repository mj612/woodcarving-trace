{"ast":null,"code":"import { mapState } from 'vuex';\nimport { updateUserInfo, changePassword } from '@/api';\nexport default {\n  name: 'Profile',\n  data() {\n    return {\n      form: {\n        username: '',\n        realName: '',\n        phone: '',\n        email: '',\n        company: '',\n        address: ''\n      },\n      passwordForm: {\n        oldPassword: '',\n        newPassword: '',\n        confirmPassword: ''\n      }\n    };\n  },\n  computed: {\n    ...mapState(['userInfo'])\n  },\n  mounted() {\n    this.loadUserInfo();\n  },\n  methods: {\n    loadUserInfo() {\n      this.form = {\n        username: this.userInfo.username,\n        realName: this.userInfo.realName || '',\n        phone: this.userInfo.phone || '',\n        email: this.userInfo.email || '',\n        company: this.userInfo.company || '',\n        address: this.userInfo.address || ''\n      };\n    },\n    async saveProfile() {\n      try {\n        await updateUserInfo({\n          realName: this.form.realName,\n          phone: this.form.phone,\n          email: this.form.email,\n          company: this.form.company,\n          address: this.form.address\n        });\n\n        // 更新本地存储的用户信息\n        this.$store.commit('SET_USER_INFO', {\n          ...this.userInfo,\n          ...this.form\n        });\n        this.$message.success('个人信息保存成功');\n      } catch (error) {\n        console.error('保存个人信息失败:', error);\n        this.$message.error('保存失败，请重试');\n      }\n    },\n    async changePassword() {\n      if (this.passwordForm.newPassword !== this.passwordForm.confirmPassword) {\n        this.$message.error('两次输入的密码不一致');\n        return;\n      }\n      if (this.passwordForm.newPassword.length < 6) {\n        this.$message.error('新密码长度不能少于6位');\n        return;\n      }\n      if (!this.passwordForm.oldPassword) {\n        this.$message.error('请输入原密码');\n        return;\n      }\n      try {\n        await changePassword({\n          oldPassword: this.passwordForm.oldPassword,\n          newPassword: this.passwordForm.newPassword\n        });\n        this.$message.success('密码修改成功，请重新登录');\n\n        // 清空表单\n        this.passwordForm = {\n          oldPassword: '',\n          newPassword: '',\n          confirmPassword: ''\n        };\n\n        // 2秒后跳转到登录页\n        setTimeout(() => {\n          // 清除token和用户信息\n          this.$store.dispatch('logout');\n          this.$router.push('/login');\n        }, 2000);\n      } catch (error) {\n        console.error('修改密码失败:', error);\n        // 根据错误信息显示不同的提示\n        if (error.response && error.response.data && error.response.data.msg) {\n          this.$message.error(error.response.data.msg);\n        } else {\n          this.$message.error('修改失败，请检查原密码是否正确');\n        }\n      }\n    },\n    resetForm() {\n      this.loadUserInfo();\n    }\n  }\n};","map":{"version":3,"names":["mapState","updateUserInfo","changePassword","name","data","form","username","realName","phone","email","company","address","passwordForm","oldPassword","newPassword","confirmPassword","computed","mounted","loadUserInfo","methods","userInfo","saveProfile","$store","commit","$message","success","error","console","length","setTimeout","dispatch","$router","push","response","msg","resetForm"],"sources":["src/views/Profile.vue"],"sourcesContent":["<template>\n  <div class=\"profile\">\n    <div class=\"page-container\">\n      <div class=\"card\">\n        <h2 class=\"form-title\">个人资料</h2>\n        \n        <el-form :model=\"form\" label-width=\"100px\">\n          <el-form-item label=\"用户名\">\n            <el-input v-model=\"form.username\" disabled></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"真实姓名\">\n            <el-input v-model=\"form.realName\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"手机号\">\n            <el-input v-model=\"form.phone\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"邮箱\">\n            <el-input v-model=\"form.email\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"公司\">\n            <el-input v-model=\"form.company\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"地址\">\n            <el-input v-model=\"form.address\" type=\"textarea\"></el-input>\n          </el-form-item>\n          \n          <el-form-item>\n            <el-button type=\"primary\" @click=\"saveProfile\">保存修改</el-button>\n            <el-button @click=\"resetForm\">重置</el-button>\n          </el-form-item>\n        </el-form>\n      </div>\n      \n      <!-- 修改密码 -->\n      <div class=\"card\">\n        <h2 class=\"form-title\">修改密码</h2>\n        \n        <el-form :model=\"passwordForm\" label-width=\"100px\">\n          <el-form-item label=\"原密码\" prop=\"oldPassword\">\n            <el-input v-model=\"passwordForm.oldPassword\" type=\"password\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"新密码\" prop=\"newPassword\">\n            <el-input v-model=\"passwordForm.newPassword\" type=\"password\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"确认密码\" prop=\"confirmPassword\">\n            <el-input v-model=\"passwordForm.confirmPassword\" type=\"password\"></el-input>\n          </el-form-item>\n          \n          <el-form-item>\n            <el-button type=\"primary\" @click=\"changePassword\">修改密码</el-button>\n          </el-form-item>\n        </el-form>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { mapState } from 'vuex'\nimport { updateUserInfo, changePassword } from '@/api'\n\nexport default {\n  name: 'Profile',\n  data() {\n    return {\n      form: {\n        username: '',\n        realName: '',\n        phone: '',\n        email: '',\n        company: '',\n        address: ''\n      },\n      passwordForm: {\n        oldPassword: '',\n        newPassword: '',\n        confirmPassword: ''\n      }\n    }\n  },\n  computed: {\n    ...mapState(['userInfo'])\n  },\n  mounted() {\n    this.loadUserInfo()\n  },\n  methods: {\n    loadUserInfo() {\n      this.form = {\n        username: this.userInfo.username,\n        realName: this.userInfo.realName || '',\n        phone: this.userInfo.phone || '',\n        email: this.userInfo.email || '',\n        company: this.userInfo.company || '',\n        address: this.userInfo.address || ''\n      }\n    },\n    \n    async saveProfile() {\n      try {\n        await updateUserInfo({\n          realName: this.form.realName,\n          phone: this.form.phone,\n          email: this.form.email,\n          company: this.form.company,\n          address: this.form.address\n        })\n        \n        // 更新本地存储的用户信息\n        this.$store.commit('SET_USER_INFO', {\n          ...this.userInfo,\n          ...this.form\n        })\n        \n        this.$message.success('个人信息保存成功')\n      } catch (error) {\n        console.error('保存个人信息失败:', error)\n        this.$message.error('保存失败，请重试')\n      }\n    },\n    \n    async changePassword() {\n      if (this.passwordForm.newPassword !== this.passwordForm.confirmPassword) {\n        this.$message.error('两次输入的密码不一致')\n        return\n      }\n      \n      if (this.passwordForm.newPassword.length < 6) {\n        this.$message.error('新密码长度不能少于6位')\n        return\n      }\n      \n      if (!this.passwordForm.oldPassword) {\n        this.$message.error('请输入原密码')\n        return\n      }\n      \n      try {\n        await changePassword({\n          oldPassword: this.passwordForm.oldPassword,\n          newPassword: this.passwordForm.newPassword\n        })\n        \n        this.$message.success('密码修改成功，请重新登录')\n        \n        // 清空表单\n        this.passwordForm = {\n          oldPassword: '',\n          newPassword: '',\n          confirmPassword: ''\n        }\n        \n        // 2秒后跳转到登录页\n        setTimeout(() => {\n          // 清除token和用户信息\n          this.$store.dispatch('logout')\n          this.$router.push('/login')\n        }, 2000)\n        \n      } catch (error) {\n        console.error('修改密码失败:', error)\n        // 根据错误信息显示不同的提示\n        if (error.response && error.response.data && error.response.data.msg) {\n          this.$message.error(error.response.data.msg)\n        } else {\n          this.$message.error('修改失败，请检查原密码是否正确')\n        }\n      }\n    },\n    \n    resetForm() {\n      this.loadUserInfo()\n    }\n  }\n}\n</script>\n\n<style scoped>\n.profile ::v-deep .el-form-item__label {\n  font-weight: bold;\n}\n</style>"],"mappings":"AAiEA,SAAAA,QAAA;AACA,SAAAC,cAAA,EAAAC,cAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,IAAA;QACAC,QAAA;QACAC,QAAA;QACAC,KAAA;QACAC,KAAA;QACAC,OAAA;QACAC,OAAA;MACA;MACAC,YAAA;QACAC,WAAA;QACAC,WAAA;QACAC,eAAA;MACA;IACA;EACA;EACAC,QAAA;IACA,GAAAhB,QAAA;EACA;EACAiB,QAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAD,aAAA;MACA,KAAAb,IAAA;QACAC,QAAA,OAAAc,QAAA,CAAAd,QAAA;QACAC,QAAA,OAAAa,QAAA,CAAAb,QAAA;QACAC,KAAA,OAAAY,QAAA,CAAAZ,KAAA;QACAC,KAAA,OAAAW,QAAA,CAAAX,KAAA;QACAC,OAAA,OAAAU,QAAA,CAAAV,OAAA;QACAC,OAAA,OAAAS,QAAA,CAAAT,OAAA;MACA;IACA;IAEA,MAAAU,YAAA;MACA;QACA,MAAApB,cAAA;UACAM,QAAA,OAAAF,IAAA,CAAAE,QAAA;UACAC,KAAA,OAAAH,IAAA,CAAAG,KAAA;UACAC,KAAA,OAAAJ,IAAA,CAAAI,KAAA;UACAC,OAAA,OAAAL,IAAA,CAAAK,OAAA;UACAC,OAAA,OAAAN,IAAA,CAAAM;QACA;;QAEA;QACA,KAAAW,MAAA,CAAAC,MAAA;UACA,QAAAH,QAAA;UACA,QAAAf;QACA;QAEA,KAAAmB,QAAA,CAAAC,OAAA;MACA,SAAAC,KAAA;QACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA,KAAAF,QAAA,CAAAE,KAAA;MACA;IACA;IAEA,MAAAxB,eAAA;MACA,SAAAU,YAAA,CAAAE,WAAA,UAAAF,YAAA,CAAAG,eAAA;QACA,KAAAS,QAAA,CAAAE,KAAA;QACA;MACA;MAEA,SAAAd,YAAA,CAAAE,WAAA,CAAAc,MAAA;QACA,KAAAJ,QAAA,CAAAE,KAAA;QACA;MACA;MAEA,UAAAd,YAAA,CAAAC,WAAA;QACA,KAAAW,QAAA,CAAAE,KAAA;QACA;MACA;MAEA;QACA,MAAAxB,cAAA;UACAW,WAAA,OAAAD,YAAA,CAAAC,WAAA;UACAC,WAAA,OAAAF,YAAA,CAAAE;QACA;QAEA,KAAAU,QAAA,CAAAC,OAAA;;QAEA;QACA,KAAAb,YAAA;UACAC,WAAA;UACAC,WAAA;UACAC,eAAA;QACA;;QAEA;QACAc,UAAA;UACA;UACA,KAAAP,MAAA,CAAAQ,QAAA;UACA,KAAAC,OAAA,CAAAC,IAA