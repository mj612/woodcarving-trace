{"ast":null,"code":"import { mapState } from 'vuex';\nexport default {\n  name: 'Layout',\n  computed: {\n    ...mapState(['userInfo'])\n  },\n  methods: {\n    handleMenuSelect(index) {\n      console.log('菜单选择:', index);\n    },\n    handleMenuClick(path) {\n      this.$router.push(path);\n    },\n    handleUserCommand(command) {\n      if (command === 'logout') {\n        this.$store.dispatch('logout');\n        this.$router.push('/login');\n      } else if (command === 'profile') {\n        this.$router.push('/profile');\n      }\n    }\n  }\n};","map":{"version":3,"names":["mapState","name","computed","methods","handleMenuSelect","index","console","log","handleMenuClick","path","$router","push","handleUserCommand","command","$store","dispatch"],"sources":["src/views/Layout.vue"],"sourcesContent":["<template>\n  <div class=\"layout\">\n    <el-container>\n      <!-- 侧边栏 -->\n      <el-aside width=\"200px\">\n        <el-menu\n          :default-active=\"$route.path\"\n          class=\"el-menu-vertical\"\n          @select=\"handleMenuSelect\"\n          router\n        >\n          <el-menu-item index=\"/dashboard\" router>\n            <i class=\"el-icon-house\"></i>\n            <span slot=\"title\">工作台</span>\n          </el-menu-item>\n          \n          <el-submenu index=\"material\">\n            <template slot=\"title\">\n              <i class=\"el-icon-box\"></i>\n              <span>原料管理</span>\n            </template>\n            <el-menu-item index=\"/dashboard/materials\">原料列表</el-menu-item>\n            <el-menu-item index=\"/dashboard/materials/create\">添加原料</el-menu-item>\n          </el-submenu>\n          \n          <el-submenu index=\"product\">\n            <template slot=\"title\">\n              <i class=\"el-icon-goods\"></i>\n              <span>产品管理</span>\n            </template>\n            <el-menu-item index=\"/dashboard/products\">产品列表</el-menu-item>\n            <el-menu-item index=\"/dashboard/products/create\">创建产品</el-menu-item>\n          </el-submenu>\n          \n          <el-menu-item index=\"/dashboard/storage\">\n            <i class=\"el-icon-office-building\"></i>\n            <span slot=\"title\">仓储管理</span>\n          </el-menu-item>\n          \n          <el-menu-item index=\"/dashboard/sales\">\n            <i class=\"el-icon-shopping-cart-full\"></i>\n            <span slot=\"title\">销售管理</span>\n          </el-menu-item>\n          \n          <el-menu-item index=\"/trace\">\n            <i class=\"el-icon-search\"></i>\n            <span slot=\"title\">溯源查询</span>\n          </el-menu-item>\n          \n          <el-menu-item index=\"/blockchain-explorer\">\n            <i class=\"el-icon-coin\"></i>\n            <span slot=\"title\">区块链浏览器</span>\n          </el-menu-item>\n          \n          <el-menu-item index=\"/dashboard/profile\">\n            <i class=\"el-icon-user\"></i>\n            <span slot=\"title\">个人中心</span>\n          </el-menu-item>\n          \n          <!-- 管理员菜单 -->\n          <el-submenu index=\"admin\" v-if=\"userInfo && userInfo.role === 'supervisor'\">\n            <template slot=\"title\">\n              <i class=\"el-icon-setting\"></i>\n              <span>系统管理</span>\n            </template>\n            <el-menu-item index=\"/dashboard/admin/users\">用户管理</el-menu-item>\n          </el-submenu>\n        </el-menu>\n      </el-aside>\n      \n      <!-- 主体内容 -->\n      <el-container>\n        <!-- 头部 -->\n        <el-header height=\"60px\" class=\"header\">\n          <div class=\"header-content\">\n            <h2>木雕工艺品溯源系统</h2>\n            <div class=\"user-info\">\n              <span>欢迎，{{ userInfo ? (userInfo.realName || userInfo.username) : '用户' }}</span>\n              <el-dropdown @command=\"handleUserCommand\">\n                <span class=\"el-dropdown-link\">\n                  <i class=\"el-icon-arrow-down el-icon--right\"></i>\n                </span>\n                <el-dropdown-menu slot=\"dropdown\">\n                  <el-dropdown-item command=\"profile\">个人中心</el-dropdown-item>\n                  <el-dropdown-item command=\"logout\">退出登录</el-dropdown-item>\n                </el-dropdown-menu>\n              </el-dropdown>\n            </div>\n          </div>\n        </el-header>\n        \n        <!-- 内容区域 -->\n        <el-main>\n          <router-view />\n        </el-main>\n      </el-container>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport { mapState } from 'vuex'\n\nexport default {\n  name: 'Layout',\n  computed: {\n    ...mapState(['userInfo'])\n  },\n  methods: {\n    handleMenuSelect(index) {\n      console.log('菜单选择:', index)\n    },\n    \n    handleMenuClick(path) {\n      this.$router.push(path)\n    },\n    \n    handleUserCommand(command) {\n      if (command === 'logout') {\n        this.$store.dispatch('logout')\n        this.$router.push('/login')\n      } else if (command === 'profile') {\n        this.$router.push('/profile')\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.layout {\n  height: 100vh;\n}\n\n.el-menu-vertical:not(.el-menu--collapse) {\n  width: 200px;\n  min-height: 400px;\n}\n\n.header {\n  background-color: #409eff;\n  color: white;\n  display: flex;\n  align-items: center;\n  box-shadow: 0 2px 4px rgba(0,0,0,.1);\n}\n\n.header-content {\n  width: 100%;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.header h2 {\n  margin: 0;\n  font-size: 20px;\n}\n\n.user-info {\n  display: flex;\n  align-items: center;\n  gap: 15px;\n}\n\n.el-dropdown-link {\n  cursor: pointer;\n  color: white;\n}\n\n.el-main {\n  padding: 0;\n  background-color: #f5f5f5;\n}\n</style>"],"mappings":"AAqGA,SAAAA,QAAA;AAEA;EACAC,IAAA;EACAC,QAAA;IACA,GAAAF,QAAA;EACA;EACAG,OAAA;IACAC,iBAAAC,KAAA;MACAC,OAAA,CAAAC,GAAA,UAAAF,KAAA;IACA;IAEAG,gBAAAC,IAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,CAAAF,IAAA;IACA;IAEAG,kBAAAC,OAAA;MACA,IAAAA,OAAA;QACA,KAAAC,MAAA,CAAAC,QAAA;QACA,KAAAL,OAAA,CAAAC,IAAA;MACA,WAAAE,OAAA;QACA,KAAAH,OAAA,C