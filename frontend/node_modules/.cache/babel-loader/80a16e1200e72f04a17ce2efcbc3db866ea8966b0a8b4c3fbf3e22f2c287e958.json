{"ast":null,"code":"import { recordSales, getProductList } from '@/api';\nexport default {\n  name: 'SalesIndex',\n  data() {\n    return {\n      activeTab: 'orders',\n      showSaleDialog: false,\n      loading: false,\n      saleForm: {\n        productId: '',\n        orderId: '',\n        buyerName: '',\n        buyerContact: '',\n        price: 0,\n        saleDate: ''\n      },\n      saleRules: {\n        productId: [{\n          required: true,\n          message: '请输入产品ID',\n          trigger: 'blur'\n        }],\n        orderId: [{\n          required: true,\n          message: '请输入订单号',\n          trigger: 'blur'\n        }],\n        buyerName: [{\n          required: true,\n          message: '请输入购买方姓名',\n          trigger: 'blur'\n        }],\n        buyerContact: [{\n          required: true,\n          message: '请输入联系方式',\n          trigger: 'blur'\n        }],\n        price: [{\n          required: true,\n          message: '请输入价格',\n          trigger: 'blur'\n        }]\n      },\n      salesOrders: []\n    };\n  },\n  mounted() {\n    this.loadSalesOrders();\n  },\n  methods: {\n    async loadSalesOrders() {\n      this.loading = true;\n      try {\n        // 获取已售产品列表\n        const res = await getProductList({\n          status: 'sold'\n        });\n        // 修复：API返回的是 { list: [], total: 0 } 格式\n        this.salesOrders = res.data && res.data.list ? res.data.list : [];\n      } catch (error) {\n        console.error('加载销售订单失败:', error);\n        this.salesOrders = [];\n      } finally {\n        this.loading = false;\n      }\n    },\n    getStatusType(status) {\n      const map = {\n        'pending': 'info',\n        'paid': 'warning',\n        'shipped': 'success',\n        'completed': 'success',\n        'cancelled': 'danger'\n      };\n      return map[status] || 'info';\n    },\n    getStatusText(status) {\n      const map = {\n        'pending': '待付款',\n        'paid': '已付款',\n        'shipped': '已发货',\n        'completed': '已完成',\n        'cancelled': '已取消'\n      };\n      return map[status] || status;\n    },\n    viewOrder(row) {\n      this.$message.info(`查看订单 ${row.orderId} 详情`);\n    },\n    updateTracking(row) {\n      this.$prompt('请输入物流单号', '更新物流信息', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消'\n      }).then(({\n        value\n      }) => {\n        this.$message.success(`物流单号已更新为: ${value}`);\n      });\n    },\n    submitSale() {\n      this.$refs.saleForm.validate(async valid => {\n        if (valid) {\n          try {\n            await recordSales(this.saleForm);\n            this.$message.success('销售记录添加成功');\n            this.showSaleDialog = false;\n            this.resetSaleForm();\n            this.loadSalesOrders();\n          } catch (error) {\n            console.error('添加销售记录失败:', error);\n            this.$message.error('添加销售记录失败');\n          }\n        }\n      });\n    },\n    resetSaleForm() {\n      this.$refs.saleForm.resetFields();\n      this.saleForm.saleDate = '';\n    }\n  }\n};","map":{"version":3,"names":["recordSales","getProductList","name","data","activeTab","showSaleDialog","loading","saleForm","productId","orderId","buyerName","buyerContact","price","saleDate","saleRules","required","message","trigger","salesOrders","mounted","loadSalesOrders","methods","res","status","list","error","console","getStatusType","map","getStatusText","viewOrder","row","$message","info","updateTracking","$prompt","confirmButtonText","cancelButtonText","then","value","success","submitSale","$refs","validate","valid","resetSaleForm","resetFields"],"sources":["src/views/sales/Index.vue"],"sourcesContent":["<template>\n  <div class=\"sales-index\">\n    <div class=\"page-container\">\n      <div class=\"action-bar\">\n        <h2>销售管理</h2>\n        <el-button type=\"primary\" @click=\"showSaleDialog = true\">记录销售</el-button>\n      </div>\n      \n      <div class=\"card\">\n        <el-tabs v-model=\"activeTab\">\n          <el-tab-pane label=\"销售订单\" name=\"orders\">\n            <el-table :data=\"salesOrders\" style=\"width: 100%\" v-loading=\"loading\">\n              <el-table-column prop=\"orderId\" label=\"订单号\" width=\"150\"></el-table-column>\n              <el-table-column prop=\"productId\" label=\"产品ID\" width=\"150\"></el-table-column>\n              <el-table-column prop=\"productName\" label=\"产品名称\" width=\"180\"></el-table-column>\n              <el-table-column prop=\"buyerName\" label=\"购买方\" width=\"120\"></el-table-column>\n              <el-table-column prop=\"price\" label=\"价格(元)\" width=\"100\"></el-table-column>\n              <el-table-column prop=\"saleDate\" label=\"销售日期\" width=\"180\"></el-table-column>\n              <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n                <template slot-scope=\"scope\">\n                  <el-tag :type=\"getStatusType(scope.row.status)\">\n                    {{ getStatusText(scope.row.status) }}\n                  </el-tag>\n                </template>\n              </el-table-column>\n              <el-table-column label=\"操作\" width=\"150\">\n                <template slot-scope=\"scope\">\n                  <el-button size=\"mini\" @click=\"viewOrder(scope.row)\">详情</el-button>\n                  <el-button size=\"mini\" type=\"primary\" @click=\"updateTracking(scope.row)\" \n                             v-if=\"scope.row.status === 'paid'\">物流</el-button>\n                </template>\n              </el-table-column>\n            </el-table>\n          </el-tab-pane>\n          \n          <el-tab-pane label=\"销售统计\" name=\"statistics\">\n            <div class=\"stats-grid\">\n              <div class=\"stat-card\">\n                <div class=\"stat-value\">¥128,500</div>\n                <div class=\"stat-label\">本月销售额</div>\n              </div>\n              <div class=\"stat-card\">\n                <div class=\"stat-value\">24</div>\n                <div class=\"stat-label\">本月订单数</div>\n              </div>\n              <div class=\"stat-card\">\n                <div class=\"stat-value\">¥5,354</div>\n                <div class=\"stat-label\">平均客单价</div>\n              </div>\n              <div class=\"stat-card\">\n                <div class=\"stat-value\">92%</div>\n                <div class=\"stat-label\">客户满意度</div>\n              </div>\n            </div>\n          </el-tab-pane>\n        </el-tabs>\n      </div>\n      \n      <!-- 销售记录对话框 -->\n      <el-dialog title=\"记录销售\" :visible.sync=\"showSaleDialog\" width=\"600px\">\n        <el-form :model=\"saleForm\" :rules=\"saleRules\" ref=\"saleForm\" label-width=\"100px\">\n          <el-form-item label=\"产品ID\" prop=\"productId\">\n            <el-input v-model=\"saleForm.productId\" placeholder=\"请输入产品ID\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"订单号\" prop=\"orderId\">\n            <el-input v-model=\"saleForm.orderId\" placeholder=\"请输入订单号\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"购买方姓名\" prop=\"buyerName\">\n            <el-input v-model=\"saleForm.buyerName\" placeholder=\"请输入购买方姓名\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"联系方式\" prop=\"buyerContact\">\n            <el-input v-model=\"saleForm.buyerContact\" placeholder=\"请输入联系方式\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"价格(元)\" prop=\"price\">\n            <el-input-number v-model=\"saleForm.price\" :min=\"0\" :step=\"100\"></el-input-number>\n          </el-form-item>\n          <el-form-item label=\"销售日期\">\n            <el-date-picker\n              v-model=\"saleForm.saleDate\"\n              type=\"datetime\"\n              placeholder=\"选择销售日期\"\n              format=\"yyyy-MM-dd HH:mm:ss\"\n              value-format=\"yyyy-MM-dd HH:mm:ss\">\n            </el-date-picker>\n          </el-form-item>\n        </el-form>\n        <div slot=\"footer\">\n          <el-button @click=\"showSaleDialog = false\">取消</el-button>\n          <el-button type=\"primary\" @click=\"submitSale\">确定</el-button>\n        </div>\n      </el-dialog>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { recordSales, getProductList } from '@/api'\n\nexport default {\n  name: 'SalesIndex',\n  data() {\n    return {\n      activeTab: 'orders',\n      showSaleDialog: false,\n      loading: false,\n      saleForm: {\n        productId: '',\n        orderId: '',\n        buyerName: '',\n        buyerContact: '',\n        price: 0,\n        saleDate: ''\n      },\n      saleRules: {\n        productId: [\n          { required: true, message: '请输入产品ID', trigger: 'blur' }\n        ],\n        orderId: [\n          { required: true, message: '请输入订单号', trigger: 'blur' }\n        ],\n        buyerName: [\n          { required: true, message: '请输入购买方姓名', trigger: 'blur' }\n        ],\n        buyerContact: [\n          { required: true, message: '请输入联系方式', trigger: 'blur' }\n        ],\n        price: [\n          { required: true, message: '请输入价格', trigger: 'blur' }\n        ]\n      },\n      salesOrders: []\n    }\n  },\n  \n  mounted() {\n    this.loadSalesOrders()\n  },\n  \n  methods: {\n    async loadSalesOrders() {\n      this.loading = true\n      try {\n        // 获取已售产品列表\n        const res = await getProductList({ status: 'sold' })\n        // 修复：API返回的是 { list: [], total: 0 } 格式\n        this.salesOrders = (res.data && res.data.list) ? res.data.list : []\n      } catch (error) {\n        console.error('加载销售订单失败:', error)\n        this.salesOrders = []\n      } finally {\n        this.loading = false\n      }\n    },\n    getStatusType(status) {\n      const map = {\n        'pending': 'info',\n        'paid': 'warning',\n        'shipped': 'success',\n        'completed': 'success',\n        'cancelled': 'danger'\n      }\n      return map[status] || 'info'\n    },\n    \n    getStatusText(status) {\n      const map = {\n        'pending': '待付款',\n        'paid': '已付款',\n        'shipped': '已发货',\n        'completed': '已完成',\n        'cancelled': '已取消'\n      }\n      return map[status] || status\n    },\n    \n    viewOrder(row) {\n      this.$message.info(`查看订单 ${row.orderId} 详情`)\n    },\n    \n    updateTracking(row) {\n      this.$prompt('请输入物流单号', '更新物流信息', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消'\n      }).then(({ value }) => {\n        this.$message.success(`物流单号已更新为: ${value}`)\n      })\n    },\n    \n    submitSale() {\n      this.$refs.saleForm.validate(async (valid) => {\n        if (valid) {\n          try {\n            await recordSales(this.saleForm)\n            this.$message.success('销售记录添加成功')\n            this.showSaleDialog = false\n            this.resetSaleForm()\n            this.loadSalesOrders()\n          } catch (error) {\n            console.error('添加销售记录失败:', error)\n            this.$message.error('添加销售记录失败')\n          }\n        }\n      })\n    },\n    \n    resetSaleForm() {\n      this.$refs.saleForm.resetFields()\n      this.saleForm.saleDate = ''\n    }\n  }\n}\n</script>\n\n<style scoped>\n.stats-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n  gap: 20px;\n  margin-top: 20px;\n}\n\n.stat-card {\n  background: white;\n  padding: 20px;\n  border-radius: 8px;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n  text-align: center;\n}\n\n.stat-value {\n  font-size: 28px;\n  font-weight: bold;\n  color: #409eff;\n  margin-bottom: 5px;\n}\n\n.stat-label {\n  color: #666;\n  font-size: 14px;\n}\n</style>"],"mappings":"AAgGA,SAAAA,WAAA,EAAAC,cAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;MACAC,cAAA;MACAC,OAAA;MACAC,QAAA;QACAC,SAAA;QACAC,OAAA;QACAC,SAAA;QACAC,YAAA;QACAC,KAAA;QACAC,QAAA;MACA;MACAC,SAAA;QACAN,SAAA,GACA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAR,OAAA,GACA;UAAAM,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAP,SAAA,GACA;UAAAK,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAN,YAAA,GACA;UAAAI,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAL,KAAA,GACA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MAEA;MACAC,WAAA;IACA;EACA;EAEAC,QAAA;IACA,KAAAC,eAAA;EACA;EAEAC,OAAA;IACA,MAAAD,gBAAA;MACA,KAAAd,OAAA;MACA;QACA;QACA,MAAAgB,GAAA,SAAArB,cAAA;UAAAsB,MAAA;QAAA;QACA;QACA,KAAAL,WAAA,GAAAI,GAAA,CAAAnB,IAAA,IAAAmB,GAAA,CAAAnB,IAAA,CAAAqB,IAAA,GAAAF,GAAA,CAAAnB,IAAA,CAAAqB,IAAA;MACA,SAAAC,KAAA;QACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA,KAAAP,WAAA;MACA;QACA,KAAAZ,OAAA;MACA;IACA;IACAqB,cAAAJ,MAAA;MACA,MAAAK,GAAA;QACA;QACA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAL,MAAA;IACA;IAEAM,cAAAN,MAAA;MACA,MAAAK,GAAA;QACA;QACA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAL,MAAA,KAAAA,MAAA;IACA;IAEAO,UAAAC,GAAA;MACA,KAAAC,QAAA,CAAAC,IAAA,SAAAF,GAAA,CAAAtB,OAAA;IACA;IAEAyB,eAAAH,GAAA;MACA,KAAAI,OAAA;QACAC,iBAAA;QACAC,gBAAA;MACA,GAAAC,IAAA;QAAAC;MAAA;QACA,KAAAP,QAAA,CAAAQ,OAAA,cAAAD,KAAA;MACA;IACA;IAEAE,WAAA;MACA,KAAAC,KAAA,CAAAnC,QAAA,CAAAoC,QAAA,OAAAC,KAAA;QACA,IAAAA,KAAA;UACA;YACA,MAAA5C,WAAA,MAAAO,QAAA;YACA,KAAAyB,QAAA,CAAAQ,OAAA;YACA,KAAAnC,cAAA;YACA,KAAAwC,aAAA;YACA,KAAAzB,eAAA;UACA,SAAAK,KAAA;YACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;YACA,KAAAO,QAAA,CAAAP,KAAA;UACA;QACA;MACA;IACA;IAEAoB,cAAA;MACA,KAAAH,KAAA,CAAAnC,QAAA,CAAAuC,WAAA;MACA,KAAAvC,QAAA,CAAAM,QAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}