{"ast":null,"code":"import { getProductDetail, transferProduct } from '@/api';\nimport { getImageUrls } from '@/utils/url';\nexport default {\n  name: 'ProductDetail',\n  data() {\n    return {\n      product: null,\n      chainData: null,\n      records: [],\n      loading: false,\n      showTransferDialog: false,\n      transferForm: {\n        toUser: '',\n        toName: '',\n        transferType: '',\n        location: '',\n        remarks: ''\n      }\n    };\n  },\n  computed: {\n    imageList() {\n      if (!this.product || !this.product.images) {\n        return [];\n      }\n      return getImageUrls(this.product.images);\n    }\n  },\n  mounted() {\n    this.loadProductDetail();\n  },\n  methods: {\n    async loadProductDetail() {\n      const productId = this.$route.params.id;\n      this.loading = true;\n      try {\n        const res = await getProductDetail(productId);\n        this.product = res.data.product;\n        this.chainData = res.data.chainData;\n        this.records = res.data.records || [];\n      } catch (error) {\n        console.error('加载产品详情失败:', error);\n        this.$message.error('加载产品详情失败');\n      } finally {\n        this.loading = false;\n      }\n    },\n    getStatusType(status) {\n      const map = {\n        'produced': 'success',\n        'in_storage': 'warning',\n        'sold': 'info'\n      };\n      return map[status] || 'info';\n    },\n    getStatusText(status) {\n      const map = {\n        'produced': '制作完成',\n        'in_storage': '库存中',\n        'sold': '已售出'\n      };\n      return map[status] || status;\n    },\n    async submitTransfer() {\n      // 验证表单\n      if (!this.transferForm.toUser || !this.transferForm.toName || !this.transferForm.transferType) {\n        this.$message.warning('请填写完整的转移信息');\n        return;\n      }\n      try {\n        await transferProduct({\n          productId: this.product.productId,\n          ...this.transferForm\n        });\n        this.$message.success('产品转移成功');\n        this.showTransferDialog = false;\n        this.resetTransferForm();\n\n        // 重新加载产品详情\n        this.loadProductDetail();\n      } catch (error) {\n        console.error('产品转移失败:', error);\n        this.$message.error('产品转移失败，请重试');\n      }\n    },\n    resetTransferForm() {\n      this.transferForm = {\n        toUser: '',\n        toName: '',\n        transferType: '',\n        location: '',\n        remarks: ''\n      };\n    }\n  }\n};","map":{"version":3,"names":["getProductDetail","transferProduct","getImageUrls","name","data","product","chainData","records","loading","showTransferDialog","transferForm","toUser","toName","transferType","location","remarks","computed","imageList","images","mounted","loadProductDetail","methods","productId","$route","params","id","res","error","console","$message","getStatusType","status","map","getStatusText","submitTransfer","warning","success","resetTransferForm"],"sources":["src/views/product/Detail.vue"],"sourcesContent":["<template>\n  <div class=\"product-detail\">\n    <div class=\"page-container\">\n      <div class=\"card\">\n        <h2 class=\"form-title\">产品详情</h2>\n        \n        <div v-if=\"product\">\n          <el-tabs type=\"border-card\">\n            <el-tab-pane label=\"基本信息\">\n              <el-descriptions :column=\"2\" border>\n                <el-descriptions-item label=\"产品ID\">{{ product.productId }}</el-descriptions-item>\n                <el-descriptions-item label=\"产品名称\">{{ chainData.productName }}</el-descriptions-item>\n                <el-descriptions-item label=\"尺寸\">{{ chainData.dimensions }}</el-descriptions-item>\n                <el-descriptions-item label=\"重量\">{{ chainData.weight }} kg</el-descriptions-item>\n                <el-descriptions-item label=\"状态\">\n                  <el-tag :type=\"getStatusType(chainData.status)\">\n                    {{ getStatusText(chainData.status) }}\n                  </el-tag>\n                </el-descriptions-item>\n                <el-descriptions-item label=\"创建时间\">{{ product.createdAt }}</el-descriptions-item>\n                <el-descriptions-item label=\"雕刻耗时\">{{ chainData.carveTime }} 小时</el-descriptions-item>\n                <el-descriptions-item label=\"原料ID\">{{ chainData.materialId }}</el-descriptions-item>\n                <el-descriptions-item label=\"工艺描述\" :span=\"2\">{{ chainData.craftDesc }}</el-descriptions-item>\n              </el-descriptions>\n            </el-tab-pane>\n            \n            <el-tab-pane label=\"图片展示\">\n              <div class=\"image-gallery\">\n                <el-image\n                  v-for=\"(img, index) in imageList\"\n                  :key=\"index\"\n                  :src=\"img\"\n                  :preview-src-list=\"imageList\"\n                  class=\"gallery-image\"\n                ></el-image>\n                <div v-if=\"!imageList || imageList.length === 0\" class=\"no-image\">\n                  暂无图片\n                </div>\n              </div>\n            </el-tab-pane>\n          </el-tabs>\n          \n          <div class=\"action-buttons\" style=\"margin-top: 20px;\">\n            <el-button @click=\"$router.back()\">返回</el-button>\n            <el-button type=\"primary\" @click=\"showTransferDialog = true\" \n                       v-if=\"chainData && chainData.status === 'produced'\">转移产品</el-button>\n          </div>\n        </div>\n        \n        <div v-else>\n          <el-alert title=\"产品不存在\" type=\"error\" show-icon></el-alert>\n        </div>\n      </div>\n      \n      <!-- 转移对话框 -->\n      <el-dialog title=\"转移产品\" :visible.sync=\"showTransferDialog\" width=\"500px\">\n        <el-form :model=\"transferForm\" label-width=\"100px\">\n          <el-form-item label=\"目标用户ID\" required>\n            <el-input v-model=\"transferForm.toUser\" placeholder=\"请输入目标用户ID\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"目标用户名\" required>\n            <el-input v-model=\"transferForm.toName\" placeholder=\"请输入目标用户名称\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"转移类型\" required>\n            <el-select v-model=\"transferForm.transferType\" placeholder=\"请选择转移类型\" style=\"width: 100%;\">\n              <el-option label=\"入库\" value=\"store_in\"></el-option>\n              <el-option label=\"出库\" value=\"store_out\"></el-option>\n              <el-option label=\"销售\" value=\"sell\"></el-option>\n            </el-select>\n          </el-form-item>\n          \n          <el-form-item label=\"位置\">\n            <el-input v-model=\"transferForm.location\" placeholder=\"请输入位置信息\"></el-input>\n          </el-form-item>\n          \n          <el-form-item label=\"备注\">\n            <el-input \n              v-model=\"transferForm.remarks\" \n              type=\"textarea\" \n              :rows=\"3\"\n              placeholder=\"请输入备注信息\"\n            ></el-input>\n          </el-form-item>\n        </el-form>\n        \n        <div slot=\"footer\">\n          <el-button @click=\"showTransferDialog = false\">取消</el-button>\n          <el-button type=\"primary\" @click=\"submitTransfer\">确定转移</el-button>\n        </div>\n      </el-dialog>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { getProductDetail, transferProduct } from '@/api'\nimport { getImageUrls } from '@/utils/url'\n\nexport default {\n  name: 'ProductDetail',\n  data() {\n    return {\n      product: null,\n      chainData: null,\n      records: [],\n      loading: false,\n      showTransferDialog: false,\n      transferForm: {\n        toUser: '',\n        toName: '',\n        transferType: '',\n        location: '',\n        remarks: ''\n      }\n    }\n  },\n  computed: {\n    imageList() {\n      if (!this.product || !this.product.images) {\n        return []\n      }\n      return getImageUrls(this.product.images)\n    }\n  },\n  mounted() {\n    this.loadProductDetail()\n  },\n  methods: {\n    async loadProductDetail() {\n      const productId = this.$route.params.id\n      this.loading = true\n      \n      try {\n        const res = await getProductDetail(productId)\n        this.product = res.data.product\n        this.chainData = res.data.chainData\n        this.records = res.data.records || []\n      } catch (error) {\n        console.error('加载产品详情失败:', error)\n        this.$message.error('加载产品详情失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    \n    getStatusType(status) {\n      const map = {\n        'produced': 'success',\n        'in_storage': 'warning',\n        'sold': 'info'\n      }\n      return map[status] || 'info'\n    },\n    \n    getStatusText(status) {\n      const map = {\n        'produced': '制作完成',\n        'in_storage': '库存中',\n        'sold': '已售出'\n      }\n      return map[status] || status\n    },\n    \n    async submitTransfer() {\n      // 验证表单\n      if (!this.transferForm.toUser || !this.transferForm.toName || !this.transferForm.transferType) {\n        this.$message.warning('请填写完整的转移信息')\n        return\n      }\n      \n      try {\n        await transferProduct({\n          productId: this.product.productId,\n          ...this.transferForm\n        })\n        \n        this.$message.success('产品转移成功')\n        this.showTransferDialog = false\n        this.resetTransferForm()\n        \n        // 重新加载产品详情\n        this.loadProductDetail()\n      } catch (error) {\n        console.error('产品转移失败:', error)\n        this.$message.error('产品转移失败，请重试')\n      }\n    },\n    \n    resetTransferForm() {\n      this.transferForm = {\n        toUser: '',\n        toName: '',\n        transferType: '',\n        location: '',\n        remarks: ''\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.image-gallery {\n  display: flex;\n  gap: 15px;\n  flex-wrap: wrap;\n}\n\n.gallery-image {\n  width: 200px;\n  height: 150px;\n  border-radius: 8px;\n  overflow: hidden;\n}\n\n.no-image {\n  color: #999;\n  font-style: italic;\n  padding: 20px;\n}\n\n.action-buttons {\n  display: flex;\n  gap: 10px;\n}\n</style>\n"],"mappings":"AAiGA,SAAAA,gBAAA,EAAAC,eAAA;AACA,SAAAC,YAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,OAAA;MACAC,SAAA;MACAC,OAAA;MACAC,OAAA;MACAC,kBAAA;MACAC,YAAA;QACAC,MAAA;QACAC,MAAA;QACAC,YAAA;QACAC,QAAA;QACAC,OAAA;MACA;IACA;EACA;EACAC,QAAA;IACAC,UAAA;MACA,UAAAZ,OAAA,UAAAA,OAAA,CAAAa,MAAA;QACA;MACA;MACA,OAAAhB,YAAA,MAAAG,OAAA,CAAAa,MAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,iBAAA;EACA;EACAC,OAAA;IACA,MAAAD,kBAAA;MACA,MAAAE,SAAA,QAAAC,MAAA,CAAAC,MAAA,CAAAC,EAAA;MACA,KAAAjB,OAAA;MAEA;QACA,MAAAkB,GAAA,SAAA1B,gBAAA,CAAAsB,SAAA;QACA,KAAAjB,OAAA,GAAAqB,GAAA,CAAAtB,IAAA,CAAAC,OAAA;QACA,KAAAC,SAAA,GAAAoB,GAAA,CAAAtB,IAAA,CAAAE,SAAA;QACA,KAAAC,OAAA,GAAAmB,GAAA,CAAAtB,IAAA,CAAAG,OAAA;MACA,SAAAoB,KAAA;QACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA,KAAAE,QAAA,CAAAF,KAAA;MACA;QACA,KAAAnB,OAAA;MACA;IACA;IAEAsB,cAAAC,MAAA;MACA,MAAAC,GAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAD,MAAA;IACA;IAEAE,cAAAF,MAAA;MACA,MAAAC,GAAA;QACA;QACA;QACA;MACA;MACA,OAAAA,GAAA,CAAAD,MAAA,KAAAA,MAAA;IACA;IAEA,MAAAG,eAAA;MACA;MACA,UAAAxB,YAAA,CAAAC,MAAA,UAAAD,YAAA,CAAAE,MAAA,UAAAF,YAAA,CAAAG,YAAA;QACA,KAAAgB,QAAA,CAAAM,OAAA;QACA;MACA;MAEA;QACA,MAAAlC,eAAA;UACAqB,SAAA,OAAAjB,OAAA,CAAAiB,SAAA;UACA,QAAAZ;QACA;QAEA,KAAAmB,QAAA,CAAAO,OAAA;QACA,KAAA3B,kBAAA;QACA,KAAA4B,iBAAA;;QAEA;QACA,KAAAjB,iBAAA;MACA,SAAAO,KAAA;QACAC,OAAA,CAAAD,KAAA,YAAAA,KAAA;QACA,KAAAE,QAAA,CAAAF,KAAA;MACA;IACA;IAEAU,kBAAA;MACA,KAAA3B,YAAA;QACAC,MAAA;QACAC,MAAA;QACAC,YAAA;QACAC,QAAA;QACAC,OAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}